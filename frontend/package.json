{
  "name": "autoworkbench-frontend",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && esbuild src/main.jsx --bundle --platform=browser --format=iife --outfile=dist/autoworkbench.js --loader:.css=css --jsx=automatic",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.9"
  }
}
